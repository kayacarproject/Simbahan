{
  "expo": {
    "name": "Simbahan",
    "slug": "simbahan",
    "version": "1.0.0",
    "scheme": "simbahan",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#FAFAF5",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A2B5E"
    },
    "android": {
      "package": "com.simbahan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A2B5E"
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#1A2B5E"
      }
    },
    "ios": {
      "bundleIdentifier": "com.simbahan.app",
      "supportsTablet": true,
      "icon": "./assets/images/icon.png",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#1A2B5E",
        "tabletImage": "./assets/images/splash-icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Simbahan",
      "shortName": "Simbahan",
      "description": "Your parish, in your pocket",
      "themeColor": "#1A2B5E",
      "backgroundColor": "#FAFAF5"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A2B5E",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A2B5E"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
     "extra": {
      "EXPO_PUBLIC_API_KEY": "sk_live_46012485b3c9824e07ee5902445bd4dc247af14740663584f5fd5b61859f62a1"
    }
   
  }
}
